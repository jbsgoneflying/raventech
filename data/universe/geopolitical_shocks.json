{
  "_meta": {
    "description": "Curated historical geopolitical shock events for Engine 12 VIX Fade calibration.",
    "fields": {
      "event_id": "Unique identifier",
      "event_date": "The shock day (Monday or first trading day after event)",
      "pre_date": "Last trading day before the event (typically Friday)",
      "event_type": "military_strike | invasion | energy_disruption | terrorist_attack | pandemic_shock",
      "description": "Brief event description",
      "vix_pre_close": "VIX close on pre_date",
      "vix_event_open": "VIX level at event_date open",
      "vix_event_close": "VIX close on event_date",
      "vix_5d_after": "VIX close 5 trading days after event_date",
      "vix_10d_after": "VIX close 10 trading days after event_date",
      "peak_vix": "Maximum VIX print in the 10 trading day window following event_date",
      "spx_gap_pct": "SPX open-to-prior-close gap on event_date (negative = down)",
      "oil_gap_pct": "Oil (WTI front month or USO proxy) gap on event_date",
      "rv_5d_after": "5-day annualized realized vol of SPX after event",
      "rv_10d_after": "10-day annualized realized vol of SPX after event",
      "secondary_spike": "true if VIX made a higher high after the initial event_date spike within 10d",
      "outcome_class": "contained | disruption | escalation"
    },
    "notes": [
      "All VIX values are spot VIX (CBOE VIX Index).",
      "Oil gap uses WTI front month as primary source, USO as proxy where needed.",
      "Realized vol is computed as annualized stdev of daily SPX returns over the window.",
      "peak_vix / vix_event_open ratio is used for empirical tail calibration in the MC engine."
    ]
  },
