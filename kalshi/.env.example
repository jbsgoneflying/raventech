# ─── Kalshi API ───────────────────────────────────────────────
# API key ID from https://kalshi.com/account/profile
KALSHI_API_KEY_ID=
# Path to RSA private key PEM file
KALSHI_PRIVATE_KEY_PATH=./kalshi-key.pem
# Or paste the key inline (newlines as \n):
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# Environment: "production" or "demo"
KALSHI_ENV=production
# Production
KALSHI_BASE_URL=https://api.elections.kalshi.com
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
# Demo (uncomment to use):
# KALSHI_BASE_URL=https://demo-api.kalshi.co
# KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2

# ─── Infrastructure ──────────────────────────────────────────
DATABASE_URL=postgresql://kalshi:kalshi_dev@localhost:5433/kalshi_monitor
REDIS_URL=redis://localhost:6380

# ─── Scoring & Alerts ────────────────────────────────────────
# Minimum anomaly_score to fire an alert [0-100]
SCORE_THRESHOLD=40
# Cooldown between alerts per market (seconds)
COOLDOWN_SECONDS=120
# Score must increase by this much to break cooldown
COOLDOWN_SCORE_DELTA=15
# Skip markets with open_interest below this
MIN_OPEN_INTEREST=50
# How often to poll for new/updated markets (ms)
MARKET_DISCOVERY_INTERVAL_MS=300000

# ─── Scoring Weights (sum to 1.0) ────────────────────────────
WEIGHT_SIZE=0.25
WEIGHT_LATE=0.20
WEIGHT_IMPACT=0.20
WEIGHT_LIQUIDITY=0.20
WEIGHT_PERSISTENCE=0.15

# ─── Polymarket API (all optional, public read-only) ─────────
ENABLE_POLYMARKET=1
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ─── Email Alerts (Resend) ────────────────────────────────────
# Set to 1 to enable email notifications for high-conviction alerts
EMAIL_ALERTS_ENABLED=0
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Comma-separated recipient email addresses
EMAIL_ALERT_TO=
# From address (must match a verified Resend domain)
EMAIL_ALERT_FROM=Flow Monitor <alerts@raven-tech.co>
# Minimum anomaly score to trigger an email [0-100]
EMAIL_SCORE_THRESHOLD=70
# Max emails per hour (prevents inbox flooding)
EMAIL_MAX_PER_HOUR=10

# ─── Server ──────────────────────────────────────────────────
API_PORT=3100
WEB_PORT=3000
LOG_LEVEL=info
