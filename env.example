ORATS_TOKEN=YOUR_ORATS_TOKEN_HERE
PORT=8000
LOG_LEVEL=INFO

# --- SSL / CA bundle (macOS local dev) ---
# If you see "SSL: CERTIFICATE_VERIFY_FAILED" when calling ORATS, your local Python/venv likely
# doesn't have a configured CA bundle. Recommended fix: ensure `certifi` is installed (in requirements.txt).
# Optional overrides:
# - ORATS_CA_BUNDLE=/path/to/cacert.pem
# - SSL_CERT_FILE=/path/to/cacert.pem
# - REQUESTS_CA_BUNDLE=/path/to/cacert.pem
# Dev-only (NOT recommended): ORATS_SSL_VERIFY=0

# Benzinga
# BENZINGA_API_KEY=YOUR_BENZINGA_API_KEY_HERE
# ENABLE_BENZINGA=0
# BENZINGA_ENABLE_EVENT_RISK=0
# BENZINGA_PREFER_V21_CALENDAR=0
# BENZINGA_TIMEOUT_S=20
# BENZINGA_CACHE_TTL_S=3600
#
# Earnings calendar fallback:
# Some tickers can be missing from Benzinga's future earnings calendar response.
# For those, we can optionally fall back to ORATS /cores snapshot fields (nextErn/nextErnTod).
# Comma-separated list of tickers:
# CALENDAR_ORATS_FALLBACK_TICKERS=TSLA,NVDA,AMZN,META,GOOGL

# ORATS Live (current-only overlays)
# ORATS Live requires a Live Data API subscription. These outputs are informational and do not affect historical stats.
# ORATS_LIVE_CACHE_TTL_S=10

# Redis (recommended; required for ORATS earnings snapshot calendar)
# REDIS_URL=redis://localhost:6379/0

# Calendar snapshot tuning
# CALENDAR_EARNINGS_SNAPSHOT_TTL_S=172800

# Financial Modeling Prep (FMP) — earnings calendar dates
# Used by `scripts/refresh_fmp_calendar_snapshot.py` to fetch `stable/earnings-calendar`
# FMP_API_KEY=your_key_here

# FMP snapshot tuning (optional)
# FMP_EARNINGS_HORIZON_DAYS=180
# FMP_EARNINGS_CALENDAR_WINDOW_DAYS=14
# FMP_EARNINGS_CALENDAR_LIMIT=10000
# FMP_EARNINGS_USE_ORATS_TOD=1

# --- Invite gate (recommended for public URL) ---
# If INVITE_CODE is set, the app requires it before serving pages or /api/*.
# Use a long random AUTH_SECRET for cookie signing.
# INVITE_CODE=RAVEN-BETA-2026
# AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# AUTH_COOKIE_NAME=raven_session
# AUTH_COOKIE_TTL_S=604800
# COOKIE_SECURE=1

# Engine 2 (SPX weekly IC) - optional
# ENABLE_ENGINE2_SPX_IC=0
# ENGINE2_LOOKBACK_YEARS_DEFAULT=3
# ENGINE2_EM_MULTS=0.7,0.8,0.9,1.0,1.1,1.2
# ENGINE2_WING_WIDTH_PTS=5,10,15,20,25
# ENGINE2_MAX_WEEKS_RETURN=120
#
# Policy (risk-only)
# ENGINE2_POLICY_MAX_BREACH_PCT=25
# ENGINE2_POLICY_MAX_OUTSIDE_WINGS_PCT=10
# ENGINE2_POLICY_MAX_MAE95_X_WING=1.0
#
# Macro proximity model (Benzinga economics)
# ENGINE2_MACRO_LAMBDA=0.35
# ENGINE2_MACRO_MULTIPLIER_CAP=2.5
# ENGINE2_MACRO_BASE_CPI=1.0
# ENGINE2_MACRO_BASE_FOMC=1.2
# ENGINE2_MACRO_BASE_NFP=0.7
# ENGINE2_MACRO_BASE_OPEX=0.4
# ENGINE2_MACRO_BASE_REFUNDING=0.5

