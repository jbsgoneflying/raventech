# Raven Desk Insight v2 — unified LLM tooltip pipeline (E14-style 9-section
# "senior quant explainer" schema). Serves every engine's per-card tooltip
# through /api/desk-insight. Legacy /api/*/explain-card URLs remain as shims.
ENABLE_DESK_INSIGHT_V2=1
DESK_INSIGHT_MODEL=gpt-5.5
DESK_INSIGHT_RATE_LIMIT_PER_MIN=60

# Market Intelligence v2 — pure-Python 3-state Gaussian HMM over a broader
# cross-asset factor universe. Single source of truth for regime, vol_state,
# and cross-asset stress. Calibrate weekly via `python -m scripts.mi_calibrate`
# or POST /api/market-intel/calibrate (admin-gated).
ENABLE_MI_V2=1
MI_HMM_STATE_COUNT=3
MI_HMM_LOOKBACK_DAYS=1260
MI_FACTOR_STALE_DAYS=1
MI_INSUFFICIENT_DATA_MISSING_FLOOR=3
MI_BOOTSTRAP_N=500
MI_MODEL_STORAGE_PATH=data/market_intel_regime_model.json
MI_REDIS_MODEL_KEY=market_intel:model:v1
MI_REDIS_MODEL_TTL_S=604800

# Admin token for /api/market-intel/calibrate (falls back to DESK_INSIGHT_ADMIN_TOKEN
# or ENGINE15_ADMIN_TOKEN / ENGINE14_ADMIN_TOKEN if not set).
MI_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Engine 1 v2 — Wing Decision Console
# ---------------------------------------------------------------------------
# Transforms E1 from a "TRADE / LEAN_PASS / PASS" verdict machine into a
# "where do I place my wings?" decision console. MC is always on; earnings
# date + timing are REQUIRED inputs; the old options-liquidity gates (which
# rarely returned reliable data for the desk's universe) are gated OFF by
# default.
ENABLE_E1_V2=1
ENABLE_E1_OPTIONS_LIQUIDITY_GATE=0
E1_REQUIRE_EVENT_DATE=1

# Wing-placement grid (comma-separated floats).
E1_WING_EM_MULTS=1.0,1.25,1.5,1.75,2.0
E1_WING_PTS=5,7.5,10

# Composite-score weights (need not sum to 1; they are renormalized).
E1_WING_SCORE_WEIGHT_GAP=0.30
E1_WING_SCORE_WEIGHT_CTC=0.20
E1_WING_SCORE_WEIGHT_MAE=0.25
E1_WING_SCORE_WEIGHT_THETA=0.15
E1_WING_SCORE_WEIGHT_CREDIT=0.10

# Score-normalization targets (tune desk posture without changing weights).
E1_WING_MAX_TOLERABLE_MAE_PCT=60.0
E1_WING_TARGET_THETA_PCT=50.0
E1_WING_TARGET_CREDIT_MULT=1.5

# Hold-window days for MAE proxy (daily OHLC).
E1_MAE_HOLD_DAYS=2

# Legacy desk-consensus verdict (TRADE / LEAN_PASS / PASS / FADE). In E1 v2
# the frontend no longer renders it above-the-fold; set this to 1 if you need
# the raw verdict string in the /api/breach response body for an external
# consumer. The LLM advisor endpoint re-computes it internally either way.
E1_EMIT_DESK_CONSENSUS=0

# ---------------------------------------------------------------------------
# Engine 15 v2 — Earnings Scenario Command Deck
# ---------------------------------------------------------------------------
# Collapses the two-step scan -> scenario UI into a single-page replay
# validator. Pulls from the shared cross-engine E1 breach-stats cache,
# supports "Simulate Top Pick" handoff from E1's Wing Console, and replaces
# the Phase-2 shims (Mon-Fri-only calendar, hard-coded intraday crush,
# guidance-risk placeholder) with tape-driven estimates.
ENABLE_E15_V2=1

# Use the real NYSE trading calendar (holidays + half-days) instead of the
# Mon-Fri heuristic when enumerating replay business days.
ENGINE15_HOLIDAY_CALENDAR=1

# empirical | fixed — empirical computes a per-ticker crush factor from
# historical open->close PnL ratios; fixed falls back to the static value
# in ENGINE15_INTRADAY_CRUSH_FACTOR (0.80 default).
ENGINE15_INTRADAY_CRUSH_MODE=empirical

# Benzinga-backed guidance-risk modifier in E15 conditioning. Auto-off
# when ENABLE_BENZINGA is 0 or the client fails to initialise.
ENGINE15_GUIDANCE_RISK_ENABLED=1
GUIDANCE_RISK_MAX_BUMP_PCT=15.0

# Parity with E1_EMIT_DESK_CONSENSUS — strips the legacy verdict fields
# from /api/earnings-ic/scenario response body when off. The LLM advisor
# still re-computes them internally.
E15_EMIT_DESK_CONSENSUS=0

# ---------------------------------------------------------------------------
# Engine 2 v2 — SPX IC Command Deck
# ---------------------------------------------------------------------------
# Transforms E2 from a weekly scan + hidden advisor into a single-page
# Wing Decision Console for index ICs. Ranked PlacementScore grid combines
# historical breach stats + Monte Carlo forward simulation + empirical
# intraweek MAE + theta capture + credit richness. MI v2 regime becomes
# the single source of truth across scan + open-trade tracker.
ENABLE_E2_V2=1

# Kill switch for the legacy desk-consensus verdict strings (TRADE /
# LEAN_PASS / PASS). Parity with E1 / E15 EMIT_DESK_CONSENSUS flags.
E2_EMIT_DESK_CONSENSUS=0

# Wing Console grid (comma-separated floats).
E2_WING_EM_MULTS=1.0,1.25,1.5,2.0
E2_WING_PTS=5,10,15

# Composite-score weights (need not sum to 1; renormalised at scoring time).
E2_WING_SCORE_WEIGHT_CLOSE=0.25
E2_WING_SCORE_WEIGHT_TOUCH=0.20
E2_WING_SCORE_WEIGHT_MAE=0.25
E2_WING_SCORE_WEIGHT_THETA=0.15
E2_WING_SCORE_WEIGHT_CREDIT=0.15

# Score-normalisation targets (tune desk posture without changing weights).
E2_WING_MAX_TOLERABLE_MAE_PCT=80.0
E2_WING_TARGET_THETA_PCT=60.0
E2_WING_TARGET_ROC_PCT=12.0

# Monte Carlo knobs. ENABLE_E2_MC defaults ON; flag is a kill-switch only.
ENABLE_E2_MC=1
E2_MC_N_SIMS=5000
E2_MC_MIN_POOL=20
E2_MC_SEED=1337
E2_MC_CONDITION_ON_REGIME=1
E2_MC_CONDITION_ON_MACRO=1
E2_MC_GBM_FALLBACK=1

# ---------------------------------------------------------------------------
# Engine 14 v2 — IC Scenario Command Deck
# ---------------------------------------------------------------------------
# Transforms E14 from a scenario-form-first page into a single-page Wing
# Decision Console on top of the analogue replay. Ranks (em_mult × wing_pts)
# placements by a 5-term composite (breach / touch / MAE / theta / credit),
# overlays MI v2 regime, layers a forward Monte Carlo on the analogue pool,
# and ships a native E14 advisor endpoint (separate from the E2 advisor
# that /reconcile still delegates to for back-compat).
ENABLE_E14_V2=1

# Parity with E1/E15/E2 — strips legacy verdict fields (reconcile.overall +
# echoed engine2.deskConsensus/recSimple) from /api/ic-scenario when off.
E14_EMIT_DESK_CONSENSUS=0

# Wing Console grid.
E14_WING_EM_MULTS=1.0,1.25,1.5,2.0
E14_WING_PTS=5,10,15

# Composite-score weights (need not sum to 1; renormalised at scoring time).
E14_WING_SCORE_WEIGHT_BREACH=0.25
E14_WING_SCORE_WEIGHT_TOUCH=0.20
E14_WING_SCORE_WEIGHT_MAE=0.25
E14_WING_SCORE_WEIGHT_THETA=0.15
E14_WING_SCORE_WEIGHT_CREDIT=0.15

# Score-normalisation targets (tune desk posture without changing weights).
E14_WING_MAX_TOLERABLE_MAE_PCT=80.0
E14_WING_TARGET_THETA_PCT=60.0
E14_WING_TARGET_ROC_PCT=12.0

# Forward Monte Carlo over the analogue pool. ENABLE_E14_MC defaults ON;
# flag is a kill-switch only.
ENABLE_E14_MC=1
E14_MC_N_SIMS=5000
E14_MC_MIN_POOL=20
E14_MC_SEED=1337
E14_MC_CONDITION_ON_REGIME=1
E14_MC_CONDITION_ON_MACRO=1
E14_MC_GBM_FALLBACK=1

# NYSE holiday calendar for chain_replay + simulator business-day math.
# Turning off reverts to the legacy session-counting path.
ENGINE14_HOLIDAY_CALENDAR=1

# New E14-native advisor (POST /api/ic-scenario/advisor). The legacy
# /reconcile?runAdvisor=true path still calls E2's advisor for back-compat.
E14_ADVISOR_ENABLED=1
E14_ADVISOR_MODEL=gpt-5.5
E14_ADVISOR_MAX_CALLS_PER_MINUTE=4

