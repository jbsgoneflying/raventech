# Raven Desk Insight v2 — unified LLM tooltip pipeline (E14-style 9-section
# "senior quant explainer" schema). Serves every engine's per-card tooltip
# through /api/desk-insight. Legacy /api/*/explain-card URLs remain as shims.
ENABLE_DESK_INSIGHT_V2=1
DESK_INSIGHT_MODEL=gpt-5.4
DESK_INSIGHT_RATE_LIMIT_PER_MIN=60

# Market Intelligence v2 — pure-Python 3-state Gaussian HMM over a broader
# cross-asset factor universe. Single source of truth for regime, vol_state,
# and cross-asset stress. Calibrate weekly via `python -m scripts.mi_calibrate`
# or POST /api/market-intel/calibrate (admin-gated).
ENABLE_MI_V2=1
MI_HMM_STATE_COUNT=3
MI_HMM_LOOKBACK_DAYS=1260
MI_FACTOR_STALE_DAYS=1
MI_INSUFFICIENT_DATA_MISSING_FLOOR=3
MI_BOOTSTRAP_N=500
MI_MODEL_STORAGE_PATH=data/market_intel_regime_model.json
MI_REDIS_MODEL_KEY=market_intel:model:v1
MI_REDIS_MODEL_TTL_S=604800

# Admin token for /api/market-intel/calibrate (falls back to DESK_INSIGHT_ADMIN_TOKEN
# or ENGINE15_ADMIN_TOKEN / ENGINE14_ADMIN_TOKEN if not set).
MI_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Engine 1 v2 — Wing Decision Console
# ---------------------------------------------------------------------------
# Transforms E1 from a "TRADE / LEAN_PASS / PASS" verdict machine into a
# "where do I place my wings?" decision console. MC is always on; earnings
# date + timing are REQUIRED inputs; the old options-liquidity gates (which
# rarely returned reliable data for the desk's universe) are gated OFF by
# default.
ENABLE_E1_V2=1
ENABLE_E1_OPTIONS_LIQUIDITY_GATE=0
E1_REQUIRE_EVENT_DATE=1

# Wing-placement grid (comma-separated floats).
E1_WING_EM_MULTS=1.0,1.25,1.5,1.75,2.0
E1_WING_PTS=5,7.5,10

# Composite-score weights (need not sum to 1; they are renormalized).
E1_WING_SCORE_WEIGHT_GAP=0.30
E1_WING_SCORE_WEIGHT_CTC=0.20
E1_WING_SCORE_WEIGHT_MAE=0.25
E1_WING_SCORE_WEIGHT_THETA=0.15
E1_WING_SCORE_WEIGHT_CREDIT=0.10

# Score-normalization targets (tune desk posture without changing weights).
E1_WING_MAX_TOLERABLE_MAE_PCT=60.0
E1_WING_TARGET_THETA_PCT=50.0
E1_WING_TARGET_CREDIT_MULT=1.5

# Hold-window days for MAE proxy (daily OHLC).
E1_MAE_HOLD_DAYS=2

# Legacy desk-consensus verdict (TRADE / LEAN_PASS / PASS / FADE). In E1 v2
# the frontend no longer renders it above-the-fold; set this to 1 if you need
# the raw verdict string in the /api/breach response body for an external
# consumer. The LLM advisor endpoint re-computes it internally either way.
E1_EMIT_DESK_CONSENSUS=0

